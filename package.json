{
  "name": "telegram-ai-bridge",
  "version": "4.1.0",
  "description": "Self-hosted Telegram bridge for heterogeneous AI coding agents (Claude Code, Codex, Gemini) with the A2A-TG envelope protocol for safe multi-agent collaboration in group chats.",
  "type": "module",
  "main": "bridge.js",
  "bin": {
    "telegram-ai-bridge": "start.js"
  },
  "files": [
    "start.js",
    "bridge.js",
    "config.js",
    "sessions.js",
    "progress.js",
    "streaming-preview.js",
    "send-retry.js",
    "file-ref-protect.js",
    "rate-limiter.js",
    "shared-context.js",
    "cron.js",
    "adapters/",
    "executor/",
    "agent/",
    "a2a/",
    "shared-context/",
    "scripts/",
    "launchd/",
    "docs/",
    "config.example.json",
    "README.md",
    "README_CN.md",
    "AGENTS.md",
    "LICENSE"
  ],
  "packageManager": "bun@1.3.9",
  "engines": {
    "bun": ">=1.3.9"
  },
  "homepage": "https://github.com/AliceLJY/telegram-ai-bridge",
  "repository": {
    "type": "git",
    "url": "https://github.com/AliceLJY/telegram-ai-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/AliceLJY/telegram-ai-bridge/issues"
  },
  "keywords": [
    "telegram",
    "claude",
    "claude-code",
    "codex",
    "gemini",
    "ai-agent",
    "multi-agent",
    "agent-to-agent",
    "a2a",
    "a2a-tg",
    "war-room",
    "self-hosted",
    "grammy",
    "cli",
    "remote-control",
    "bun"
  ],
  "scripts": {
    "start": "bun start.js start",
    "bootstrap": "bun start.js bootstrap",
    "check": "bun start.js check",
    "setup": "bun start.js setup",
    "config": "bun start.js config",
    "bridge": "bun bridge.js",
    "agent": "bun agent/server.js",
    "test": "bun test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.117",
    "@openai/codex-sdk": "0.121.0",
    "croner": "^9.0.0",
    "google-auth-library": "^9.0.0",
    "grammy": "^1.40.0",
    "https-proxy-agent": "^7.0.6",
    "ioredis": "^5.10.0"
  }
}
