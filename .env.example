# Legacy fallback config. New installs should prefer `config.json` via `bun run setup`.

TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
OWNER_TELEGRAM_ID=your-telegram-user-id
HTTPS_PROXY=http://127.0.0.1:7897

# Default backend: claude, codex, or gemini
# Each instance should set this to its own backend
DEFAULT_BACKEND=claude

# SQLite DB filename (use different names for each instance to avoid conflicts)
# e.g., sessions.db for Claude, sessions-codex.db for Codex, sessions-gemini.db for Gemini
SESSIONS_DB=sessions.db

# Claude Code SDK options
CC_MODEL=claude-sonnet-4-6
CC_CWD=/Users/you

# Codex SDK options (leave empty to use codex default)
CODEX_MODEL=

# Progress display verbosity: 0=off, 1=tool names, 2=tool names+input+reasoning
DEFAULT_VERBOSE_LEVEL=1

# Group shared context (group/supergroup only)
ENABLE_GROUP_SHARED_CONTEXT=true
GROUP_CONTEXT_MAX_MESSAGES=30
GROUP_CONTEXT_MAX_TOKENS=3000
GROUP_CONTEXT_TTL_MS=1200000

# Deduplicate repeated triggers
TRIGGER_DEDUP_TTL_MS=300000

# Session timeout in milliseconds (default: 15 min = 900000)
SESSION_TIMEOUT_MS=900000

# Claude permission mode: "default" (asks for confirmation) or "bypassPermissions" (skip all)
# WARNING: bypassPermissions skips ALL tool permission checks — use with caution
CC_PERMISSION_MODE=default
